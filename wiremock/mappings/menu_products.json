{
  "request": {
    "method": "GET",
    "urlPattern": "/menu/([0-9]+)/products",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      }
    }
  },
  "response": {
    "status": 200,
    "bodyFileName": "menu-products.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}