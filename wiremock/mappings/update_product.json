{
  "request": {
    "method": "PUT",
    "urlPattern": "/menu/([0-9]+)/product/([0-9]+)",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      },
      "Content-Type": {
        "matches": "application/json.*"
      }
    }
  },
  "response": {
    "status": 200,
    "transformers": ["response-template"],
    "body": "{ \"data\": {{request.body}} }",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}